# Web service
DEEPAUDIT_SERVER_PORT=8080
DEEPAUDIT_STORAGE_ROOT=./data

# PostgreSQL
DEEPAUDIT_DATASOURCE_URL=jdbc:postgresql://localhost:5432/deepaudit
DEEPAUDIT_DATASOURCE_USERNAME=deepaudit
DEEPAUDIT_DATASOURCE_PASSWORD=replace-with-your-database-password
DEEPAUDIT_DATASOURCE_DRIVER=org.postgresql.Driver

# Chat model
DEEPAUDIT_AI_BASE_URL=https://api.deepseek.com
DEEPAUDIT_AI_API_KEY=replace-with-your-api-key
DEEPAUDIT_AI_MODEL=deepseek-v4-flash

# Embedding model
DEEPAUDIT_EMBEDDING_PROVIDER=remote
DEEPAUDIT_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
DEEPAUDIT_EMBEDDING_API_KEY=replace-with-your-api-key
DEEPAUDIT_EMBEDDING_MODEL=BAAI/bge-m3
