<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.deepaudit.mapper.EmbeddingCacheMapper">
    <resultMap id="EmbeddingCacheResultMap" type="com.deepaudit.domain.EmbeddingCacheEntry">
        <id column="cache_key" property="cacheKey"/>
        <result column="embedding" property="embedding"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByKeys" resultMap="EmbeddingCacheResultMap">
        SELECT cache_key, embedding, created_at
        FROM embedding_cache
        WHERE cache_key IN
        <foreach collection="keys" item="key" open="(" separator="," close=")">#{key}</foreach>
    </select>

    <insert id="insertBatch">
        INSERT INTO embedding_cache (cache_key, embedding, created_at)
        VALUES
        <foreach collection="entries" item="entry" separator=",">
            (#{entry.cacheKey}, #{entry.embedding}, #{entry.createdAt})
        </foreach>
    </insert>
</mapper>
