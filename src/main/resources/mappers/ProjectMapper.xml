<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.deepaudit.mapper.ProjectMapper">
    <resultMap id="ProjectResultMap" type="com.deepaudit.domain.Project">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="original_filename" property="originalFilename"/>
        <result column="storage_path" property="storagePath"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="columns">id, name, original_filename, storage_path, created_at</sql>

    <insert id="insert" parameterType="com.deepaudit.domain.Project">
        INSERT INTO audit_project (id, name, original_filename, storage_path, created_at)
        VALUES (#{id}, #{name}, #{originalFilename}, #{storagePath}, #{createdAt})
    </insert>

    <select id="findById" resultMap="ProjectResultMap">
        SELECT <include refid="columns"/>
        FROM audit_project
        WHERE id = #{id}
    </select>
</mapper>
